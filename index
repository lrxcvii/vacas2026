<script>
// ── BASES FIJAS POR DESTINO (COP) ──
// cov: vuelo MDE×2 726K + vuelo PEI×2 1118K + traslados 320K + aloj 0 + comida 1200K
const BASE = {
  cov: 726000 + 1118000 + 320000 + 0 + 1200000,
  // col: vuelo MDE×2 742800 + vuelo PEI×2 1084320 + aloj 1500000 + comida 1600000
  col: 742800 + 1084320 + 1500000 + 1600000,
  // cur: vuelo MDE×2 2577342 + vuelo PEI×2 2774380 + aloj 1900000 + auto 385000 + comida 3100000
  cur: 2577342 + 2774380 + 1900000 + 385000 + 3100000,
  // mex: vuelo MDE×2 2908480 + vuelo PEI×2 3778080 + aloj 1480000 + auto 266000 + comida 2700000
  mex: 2908480 + 3778080 + 1480000 + 266000 + 2700000
};

function fmt(n){
  if(n>=1e6){
    const m=n/1e6;
    const s=m%1===0?m.toFixed(0):m.toFixed(2).replace(/\.?0+$/,'');
    return '$'+s+'M';
  }
  return '$'+Math.round(n/1000)+'K';
}

function getTours(dest){
  let total=0,lines=[];
  document.querySelectorAll(`.tour-card[data-dest="${dest}"].selected`).forEach(c=>{
    const p=parseInt(c.dataset.price);
    const name=c.querySelector('.tour-name').textContent.replace(/★.*/,'').trim().substring(0,36);
    total+=p; lines.push({name,p});
  });
  return{total,lines};
}

function updateTotal(dest){
  const{total:tTotal,lines}=getTours(dest);
  const grand=BASE[dest]+tTotal;
  const priceEl=document.getElementById(`${dest}-price`);
  const ppEl=document.getElementById(`${dest}-pp`);
  const bdEl=document.getElementById(`${dest}-bd`);
  priceEl.classList.add('price-changed');
  setTimeout(()=>priceEl.classList.remove('price-changed'),350);
  priceEl.textContent=fmt(grand);
  ppEl.textContent='≈ '+fmt(Math.round(grand/4))+' por persona';
  bdEl.innerHTML=lines.length
    ?`<div class="bd-tours-title">Tours seleccionados</div>`+lines.map(l=>`<div class="bd-tour-line">${l.name}<span>${fmt(l.p)}</span></div>`).join('')
    :'';
  const tCell=document.getElementById(`cmp-${dest}-t`);
  tCell.textContent=tTotal?fmt(tTotal):'—';
  const totCell=document.getElementById(`cmp-${dest}-total`);
  const badge=totCell.querySelector('.badge-xs');
  totCell.childNodes[0].textContent=fmt(grand)+' ';
}

function toggleTour(card){
  const dest=card.dataset.dest;
  const check=card.querySelector('.tour-check');
  const cta=card.querySelector('.tour-cta');
  const sel=card.classList.contains('selected');
  card.classList.toggle('selected');
  if(sel){check.textContent='';if(cta){cta.className='tour-cta off';cta.textContent='+ Añadir';}}
  else{check.textContent='✓';if(cta){cta.className='tour-cta on';cta.textContent='Añadido ✓';}}
  updateTotal(dest);
}

window.addEventListener('DOMContentLoaded',()=>['cov','col','cur','mex'].forEach(updateTotal));

// Reveal
const obs=new IntersectionObserver(e=>e.forEach(x=>{if(x.isIntersecting)x.target.classList.add('visible');}),{threshold:.08});
document.querySelectorAll('.reveal').forEach(r=>obs.observe(r));

// Nav highlight
const secs=document.querySelectorAll('section[id]');
window.addEventListener('scroll',()=>{
  let cur='';
  secs.forEach(s=>{if(window.scrollY>=s.offsetTop-140)cur=s.id;});
  document.querySelectorAll('.dest-nav a').forEach(a=>a.classList.toggle('active',a.getAttribute('href')==='#'+cur));
},{passive:true});
</script>
