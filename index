<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Vacaciones Mayo 2026 — 2 Parejas</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root{
  --deep:#0E2A3A; --gold:#C8973A;
  --cov-c:#f0c97a; --cov-bg:#1C1200;
  --col-c:#f5a995; --col-bg:#200A08;
  --cur-c:#90caf9; --cur-bg:#071525;
  --mex-c:#81d17f; --mex-bg:#0A1F15;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--deep);color:#fff;overflow-x:hidden}

/* HERO */
.hero{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;position:relative;overflow:hidden;padding:2rem;background:var(--deep)}
.hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 50% 40%,#1a4a5a 0%,var(--deep) 70%)}
.hero-dots{position:absolute;inset:0;background-image:radial-gradient(circle,rgba(200,151,58,.18) 1px,transparent 1px);background-size:40px 40px}
.hero-content{position:relative;z-index:1;max-width:800px}
.hero-badge{display:inline-block;font-size:.7rem;font-weight:500;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);border:1px solid rgba(200,151,58,.4);padding:.4rem 1.2rem;border-radius:100px;margin-bottom:1.5rem;animation:fadeUp .8s ease both}
.hero h1{font-family:'Playfair Display',serif;font-size:clamp(2.8rem,7vw,5.5rem);line-height:1.05;margin-bottom:1rem;animation:fadeUp .8s ease .15s both}
.hero h1 em{font-style:italic;color:var(--gold)}
.hero-sub{font-size:1rem;color:rgba(255,255,255,.6);margin-bottom:2.5rem;animation:fadeUp .8s ease .3s both}
.hero-stats{display:flex;gap:2.5rem;justify-content:center;flex-wrap:wrap;animation:fadeUp .8s ease .45s both}
.hero-stat .num{display:block;font-family:'Playfair Display',serif;font-size:2rem;color:var(--gold);font-weight:700}
.hero-stat .lbl{font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.45)}
.scroll-hint{position:absolute;bottom:2rem;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:.4rem;color:rgba(255,255,255,.3);font-size:.65rem;letter-spacing:.15em;text-transform:uppercase;animation:bounce 2s infinite;z-index:1}
.scroll-hint::after{content:'';display:block;width:1px;height:40px;background:rgba(255,255,255,.2)}

/* NAV */
.dest-nav{background:rgba(14,42,58,.97);backdrop-filter:blur(12px);position:sticky;top:0;z-index:100;border-bottom:1px solid rgba(255,255,255,.08)}
.dest-nav ul{display:flex;list-style:none;justify-content:center;max-width:1100px;margin:0 auto;flex-wrap:wrap}
.dest-nav a{display:flex;align-items:center;gap:.35rem;padding:.9rem 1.2rem;text-decoration:none;font-size:.72rem;font-weight:500;letter-spacing:.09em;text-transform:uppercase;color:rgba(255,255,255,.35);border-bottom:2px solid transparent;transition:all .2s;white-space:nowrap}
.dest-nav a.cov:hover,.dest-nav a.cov.active{border-color:var(--cov-c);color:var(--cov-c)}
.dest-nav a.col:hover,.dest-nav a.col.active{border-color:var(--col-c);color:var(--col-c)}
.dest-nav a.cur:hover,.dest-nav a.cur.active{border-color:var(--cur-c);color:var(--cur-c)}
.dest-nav a.mex:hover,.dest-nav a.mex.active{border-color:var(--mex-c);color:var(--mex-c)}
.dest-nav a.cmp:hover{color:var(--gold)}

/* SECTIONS */
section.dest-section{min-height:100vh;padding:5rem 1.5rem}
.dest-inner{max-width:1000px;margin:0 auto}
.dest-header{display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start;margin-bottom:2.5rem}
@media(max-width:700px){.dest-header{grid-template-columns:1fr;gap:2rem}}
.dest-tag{display:inline-block;font-size:.62rem;font-weight:500;letter-spacing:.2em;text-transform:uppercase;padding:.28rem .85rem;border-radius:100px;margin-bottom:.8rem}
.dest-title{font-family:'Playfair Display',serif;font-size:clamp(2rem,5vw,3.3rem);line-height:1.1;margin-bottom:.4rem}
.dest-subtitle{font-size:.8rem;color:rgba(255,255,255,.36);letter-spacing:.07em;margin-bottom:1rem}
.dest-desc{font-size:.87rem;line-height:1.75;color:rgba(255,255,255,.6)}
.quick-facts{display:grid;grid-template-columns:repeat(2,1fr);gap:.62rem}
.fact{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:.72rem .88rem}
.fact-label{font-size:.57rem;text-transform:uppercase;letter-spacing:.14em;color:rgba(255,255,255,.26);margin-bottom:.2rem}
.fact-value{font-size:.84rem;font-weight:500}

/* ALERTS */
.alert{display:flex;align-items:flex-start;gap:.65rem;border-radius:10px;padding:.72rem .9rem;font-size:.75rem;margin-bottom:1.1rem;line-height:1.5}
.alert.good{background:rgba(80,180,100,.07);border:1px solid rgba(80,180,100,.2);color:#80d090}
.alert.warn{background:rgba(200,151,58,.08);border:1px solid rgba(200,151,58,.22);color:#e8c070}
.alert.danger{background:rgba(239,83,60,.07);border:1px solid rgba(239,83,60,.2);color:#f5a995}

/* FLIGHTS */
.section-label{font-size:.62rem;text-transform:uppercase;letter-spacing:.18em;color:rgba(255,255,255,.23);margin-bottom:.75rem}
.flights-block{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:13px;padding:1rem;margin-bottom:1.1rem}
.flight-row{display:flex;align-items:center;justify-content:space-between;padding:.55rem 0;border-bottom:1px solid rgba(255,255,255,.05);gap:.8rem}
.flight-row:last-child{border-bottom:none}
.flight-origin{font-size:.77rem;color:rgba(255,255,255,.45);min-width:72px}
.flight-arrow{color:rgba(255,255,255,.14);font-size:.73rem;flex:1;text-align:center}
.flight-price{font-size:.88rem;font-weight:600}
.flight-airline{font-size:.63rem;color:rgba(255,255,255,.3)}
.flight-detail{font-size:.62rem;color:rgba(255,255,255,.26)}
.flight-info{text-align:right}

/* CARDS */
.cards-row{display:grid;grid-template-columns:repeat(3,1fr);gap:.82rem;margin-bottom:1.7rem}
@media(max-width:700px){.cards-row{grid-template-columns:1fr}}
.info-card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:13px;padding:1.05rem}
.card-icon{font-size:1.2rem;margin-bottom:.5rem}
.card-title{font-size:.58rem;text-transform:uppercase;letter-spacing:.14em;color:rgba(255,255,255,.27);margin-bottom:.28rem}
.card-main{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;margin-bottom:.22rem}
.card-detail{font-size:.7rem;color:rgba(255,255,255,.4);line-height:1.5}

/* TOURS */
.tours-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:.72rem;margin-bottom:1.7rem}
@media(max-width:620px){.tours-grid{grid-template-columns:1fr}}
.tour-card{background:rgba(255,255,255,.03);border:1.5px solid rgba(255,255,255,.08);border-radius:13px;padding:.9rem 1rem;cursor:pointer;transition:background .18s,border-color .18s,transform .13s;user-select:none;position:relative}
.tour-card:hover{background:rgba(255,255,255,.06);transform:translateY(-1px)}
.tour-card.cov-tour.selected{border-color:rgba(240,201,122,.35);background:rgba(240,201,122,.05)}
.tour-card.col-tour.selected{border-color:rgba(245,169,149,.35);background:rgba(245,169,149,.05)}
.tour-card.cur-tour.selected{border-color:rgba(144,202,249,.35);background:rgba(144,202,249,.05)}
.tour-card.mex-tour.selected{border-color:rgba(129,209,127,.35);background:rgba(129,209,127,.05)}
.tour-check{position:absolute;top:.78rem;right:.82rem;width:21px;height:21px;border-radius:50%;border:1.5px solid rgba(255,255,255,.17);display:flex;align-items:center;justify-content:center;font-size:.63rem;font-weight:700;transition:all .18s}
.cov-tour.selected .tour-check{background:var(--cov-c);border-color:var(--cov-c);color:#1C1200}
.col-tour.selected .tour-check{background:var(--col-c);border-color:var(--col-c);color:#3d1510}
.cur-tour.selected .tour-check{background:var(--cur-c);border-color:var(--cur-c);color:#071525}
.mex-tour.selected .tour-check{background:var(--mex-c);border-color:var(--mex-c);color:#0A1F15}
.tour-header{display:flex;align-items:flex-start;gap:.42rem;margin-bottom:.28rem;padding-right:1.8rem}
.tour-num{font-size:.58rem;font-weight:600;color:rgba(255,255,255,.26);min-width:15px;padding-top:3px}
.tour-name{font-size:.82rem;font-weight:500;line-height:1.3}
.star-pill{display:inline-block;font-size:.52rem;padding:.08rem .4rem;border-radius:100px;background:rgba(200,151,58,.16);color:var(--gold);margin-left:.22rem;vertical-align:middle}
.tour-desc{font-size:.71rem;color:rgba(255,255,255,.38);line-height:1.44;margin-bottom:.52rem;padding-left:1.25rem}
.tour-footer{display:flex;align-items:flex-end;justify-content:space-between;padding-left:1.25rem}
.tour-price{font-size:.8rem;font-weight:700}
.tour-price-sub{font-size:.61rem;color:rgba(255,255,255,.3);margin-top:.04rem}
.tour-cta{font-size:.61rem;transition:color .15s}
.tour-cta.off{color:rgba(255,255,255,.26)}
.tour-cta.on{color:rgba(255,255,255,.52)}

/* TOTAL */
.total-block{border-radius:15px;padding:1.5rem 1.7rem;margin-top:.4rem}
.total-label{font-size:.62rem;text-transform:uppercase;letter-spacing:.16em;color:rgba(255,255,255,.33);margin-bottom:.45rem}
.total-row{display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:1.4rem}
.total-price-big{font-family:'Playfair Display',serif;font-size:2.4rem;font-weight:700;line-height:1;transition:all .25s}
.total-price-sub{font-size:.71rem;color:rgba(255,255,255,.36);margin-top:.18rem}
.total-breakdown{display:grid;grid-template-columns:1fr 1fr;gap:.32rem 1.6rem}
.bd-item{font-size:.73rem;color:rgba(255,255,255,.42);display:flex;justify-content:space-between;gap:.7rem}
.bd-item span{font-weight:500}
.bd-tours{margin-top:.5rem;padding-top:.42rem;border-top:1px solid rgba(255,255,255,.07)}
.bd-tours-title{font-size:.58rem;text-transform:uppercase;letter-spacing:.12em;color:rgba(255,255,255,.18);margin-bottom:.28rem}
.bd-tour-line{font-size:.68rem;color:rgba(255,255,255,.36);display:flex;justify-content:space-between;gap:.7rem;padding:.08rem 0}
.bd-tour-line span{font-weight:500}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.72}}
.price-changed{animation:pulse .3s ease}

/* DEST COLORS */
#covenas{background:linear-gradient(180deg,var(--cov-bg) 0%,var(--deep) 100%)}
.cov-accent{color:var(--cov-c)}
.cov-tag{background:rgba(240,201,122,.12);color:var(--cov-c);border:1px solid rgba(240,201,122,.28)}
.cov-bl{border-left:3px solid #D4A833}
.cov-total{background:linear-gradient(135deg,#2a1d00 0%,#0e2a3a 100%);border:1px solid rgba(240,201,122,.2)}

#santamarta{background:linear-gradient(180deg,var(--col-bg) 0%,var(--deep) 100%)}
.col-accent{color:var(--col-c)}
.col-tag{background:rgba(239,119,94,.12);color:var(--col-c);border:1px solid rgba(239,119,94,.28)}
.col-bl{border-left:3px solid #EF7B5E}
.col-total{background:linear-gradient(135deg,#3d1510 0%,#0e2a3a 100%);border:1px solid rgba(239,119,94,.2)}

#curazao{background:linear-gradient(180deg,var(--cur-bg) 0%,var(--deep) 100%)}
.cur-accent{color:var(--cur-c)}
.cur-tag{background:rgba(66,165,245,.12);color:var(--cur-c);border:1px solid rgba(66,165,245,.28)}
.cur-bl{border-left:3px solid #42A5F5}
.cur-total{background:linear-gradient(135deg,#0d2540 0%,#0e2a3a 100%);border:1px solid rgba(66,165,245,.2)}

#mexico{background:linear-gradient(180deg,var(--mex-bg) 0%,var(--deep) 100%)}
.mex-accent{color:var(--mex-c)}
.mex-tag{background:rgba(76,175,80,.12);color:var(--mex-c);border:1px solid rgba(76,175,80,.28)}
.mex-bl{border-left:3px solid #4CAF50}
.mex-total{background:linear-gradient(135deg,#1a3d22 0%,#0e2a3a 100%);border:1px solid rgba(76,175,80,.2)}

/* COMPARISON */
#comparacion{background:var(--deep);padding:5rem 1.5rem}
.comp-header{text-align:center;max-width:620px;margin:0 auto 2.5rem}
.comp-header h2{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,4vw,2.8rem);margin-bottom:.5rem}
.comp-header p{font-size:.83rem;color:rgba(255,255,255,.33)}
.comp-wrap{max-width:1100px;margin:0 auto;overflow-x:auto;padding:0 .5rem}
table.ctbl{width:100%;border-collapse:collapse;font-size:.78rem;min-width:650px}
.ctbl th{padding:.62rem .85rem;text-align:left;font-size:.58rem;text-transform:uppercase;letter-spacing:.14em;color:rgba(255,255,255,.24);border-bottom:1px solid rgba(255,255,255,.07);white-space:nowrap}
.ctbl td{padding:.82rem .85rem;border-bottom:1px solid rgba(255,255,255,.05);color:rgba(255,255,255,.62)}
.ctbl tr:last-child td{border-bottom:none}
.ctbl tr:hover td{background:rgba(255,255,255,.02)}
.dp{display:inline-flex;align-items:center;gap:.33rem;font-weight:500;color:#fff;font-size:.8rem}
.pdot{width:7px;height:7px;border-radius:50%}
.tc{font-weight:700;font-size:.86rem;color:#fff!important}
.badge-xs{display:inline-block;font-size:.5rem;padding:.1rem .38rem;border-radius:100px;margin-left:.22rem;vertical-align:middle}
.pros-grid{max-width:1100px;margin:2.2rem auto 0;display:grid;grid-template-columns:repeat(4,1fr);gap:.82rem;padding:0 .5rem}
@media(max-width:800px){.pros-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:500px){.pros-grid{grid-template-columns:1fr}}
.pros-card{background:rgba(255,255,255,.03);border-radius:12px;padding:1.1rem}
.pros-title{font-size:.58rem;text-transform:uppercase;letter-spacing:.14em;color:rgba(255,255,255,.23);margin-bottom:.65rem}
.pros-list{font-size:.76rem;color:rgba(255,255,255,.55);line-height:1.85}

footer{text-align:center;padding:2.2rem 1.5rem;background:rgba(0,0,0,.18);border-top:1px solid rgba(255,255,255,.05)}
footer p{font-size:.68rem;color:rgba(255,255,255,.15);margin-bottom:.18rem}

/* REVEAL */
.reveal{opacity:0;transform:translateY(26px);transition:opacity .6s ease,transform .6s ease}
.reveal.visible{opacity:1;transform:none}
.rd1{transition-delay:.1s}.rd2{transition-delay:.2s}.rd3{transition-delay:.3s}
@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:none}}
@keyframes bounce{0%,100%{transform:translateX(-50%) translateY(0)}50%{transform:translateX(-50%) translateY(6px)}}
</style>
</head>
<body>

<!-- HERO -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-dots"></div>
  <div class="hero-content">
    <div class="hero-badge">✈ Propuesta de viaje 2026</div>
    <h1>Vacaciones<br>de <em>verano</em></h1>
    <p class="hero-sub">2 parejas · Medellín · Mayo 22–27 · 5 noches</p>
    <div class="hero-stats">
      <div class="hero-stat"><span class="num">4</span><span class="lbl">Destinos</span></div>
      <div class="hero-stat"><span class="num">5</span><span class="lbl">Noches</span></div>
      <div class="hero-stat"><span class="num">4</span><span class="lbl">Personas</span></div>
      <div class="hero-stat"><span class="num">Mayo</span><span class="lbl">2026</span></div>
    </div>
  </div>
  <div class="scroll-hint">Explorar</div>
</section>

<!-- NAV -->
<nav class="dest-nav">
  <ul>
    <li><a href="#covenas" class="cov">🏖 Coveñas</a></li>
    <li><a href="#santamarta" class="col">🇨🇴 Santa Marta</a></li>
    <li><a href="#curazao" class="cur">🇨🇼 Curazao</a></li>
    <li><a href="#mexico" class="mex">🇲🇽 México</a></li>
    <li><a href="#comparacion" class="cmp">Comparar</a></li>
  </ul>
</nav>

<!-- ══════════════════════════════
  01 — COVEÑAS
══════════════════════════════ -->
<section id="covenas" class="dest-section">
<div class="dest-inner">

  <div class="dest-header reveal">
    <div>
      <span class="dest-tag cov-tag">Destino 01</span>
      <h2 class="dest-title">Coveñas<br><span class="cov-accent">Caribe Cordobés</span></h2>
      <p class="dest-subtitle">🇨🇴 Colombia · Córdoba · Sin visa · En pesos</p>
      <p class="dest-desc">El Caribe colombiano más cercano y económico. Coveñas tiene playas tranquilas, aguas cálidas, ambiente familiar y acceso fácil desde el interior del país. Sin sargazo, vuelos cortos desde Montería y la opción más barata del grupo. Perfecto para desconectar sin complicaciones.</p>
    </div>
    <div class="quick-facts reveal rd1">
      <div class="fact"><div class="fact-label">Clima mayo</div><div class="fact-value">☀ 30–34°C · Muy soleado</div></div>
      <div class="fact"><div class="fact-label">Sargazo</div><div class="fact-value" style="color:#80d090">✅ Sin riesgo</div></div>
      <div class="fact"><div class="fact-label">Ruta MDE</div><div class="fact-value">MDE → MTR → Coveñas</div></div>
      <div class="fact"><div class="fact-label">Ruta PEI</div><div class="fact-value">PEI → MTR → Coveñas</div></div>
    </div>
  </div>

  <div class="alert good reveal">✅ <strong>Sin sargazo · Más barato del grupo.</strong> Vuelos cortos a Montería y luego ~2h en bus o taxi hasta Coveñas. No requiere visa ni dólares. La opción ideal para presupuesto ajustado.</div>

  <div class="reveal">
    <p class="section-label">✈ VUELOS A MONTERÍA · VIE 22 MAYO</p>
    <div class="flights-block">
      <div class="flight-row">
        <div class="flight-origin">MDE → MTR</div>
        <div class="flight-arrow">── Avianca ──→</div>
        <div class="flight-info">
          <div class="flight-airline">Vuelo directo · ~1h · Aeropuerto Los Garzones</div>
          <div class="flight-price cov-accent">COP 363.000 / persona</div>
          <div class="flight-detail">ida y vuelta · 2 personas MDE = $726K COP</div>
        </div>
      </div>
      <div class="flight-row">
        <div class="flight-origin">PEI → MTR</div>
        <div class="flight-arrow">── Avianca ──→</div>
        <div class="flight-info">
          <div class="flight-airline">1 escala · ~3h total · Aeropuerto Los Garzones</div>
          <div class="flight-price cov-accent">COP 559.000 / persona</div>
          <div class="flight-detail">ida y vuelta · 2 personas PEI = $1.12M COP</div>
        </div>
      </div>
      <div class="flight-row">
        <div class="flight-origin">MTR → Coveñas</div>
        <div class="flight-arrow">── Bus / taxi ──→</div>
        <div class="flight-info">
          <div class="flight-airline">~2h en carretera · Autobús ~$15K o taxi ~$80K/viaje</div>
          <div class="flight-price cov-accent">~$320K COP</div>
          <div class="flight-detail">traslado grupal ida y vuelta × 4 personas</div>
        </div>
      </div>
    </div>
  </div>

  <div class="cards-row reveal rd1">
    <div class="info-card cov-bl">
      <div class="card-icon">🏠</div>
      <div class="card-title">Alojamiento · 5 noches</div>
      <div class="card-main cov-accent">$0</div>
      <div class="card-detail">Alojamiento propio o con familia<br>Sin costo de hospedaje<br>Añade tours y comida al total</div>
    </div>
    <div class="info-card cov-bl">
      <div class="card-icon">🍽</div>
      <div class="card-title">Comida estimada · 5 días</div>
      <div class="card-main cov-accent">$1.20M</div>
      <div class="card-detail">~$15 USD/persona/día<br>Mariscos frescos · Restaurantes locales<br>Arroz con coco · Pargo frito · Jugos</div>
    </div>
    <div class="info-card cov-bl">
      <div class="card-icon">🚌</div>
      <div class="card-title">Transporte local</div>
      <div class="card-main cov-accent">Incluido</div>
      <div class="card-detail">Traslado MTR–Coveñas ya contado<br>Mototaxis locales: ~$5K por trayecto<br>Taxis: ~$15–20K por trayecto</div>
    </div>
  </div>

  <div class="reveal">
    <p class="section-label">🎯 TOURS Y ACTIVIDADES — CLIC PARA AÑADIR AL TOTAL</p>
    <div class="tours-grid">

      <div class="tour-card cov-tour selected" data-dest="cov" data-price="280000" onclick="toggleTour(this)">
        <div class="tour-check">✓</div>
        <div class="tour-header"><span class="tour-num">01</span><span class="tour-name">Tour Islas del Rosario <span class="star-pill">★ top</span></span></div>
        <div class="tour-desc">Catamaran a las Islas del Rosario desde Coveñas · Snorkel · Acuario · Playa blanca · Almuerzo incluido · Día completo</div>
        <div class="tour-footer">
          <div><div class="tour-price cov-accent">$280.000 COP</div><div class="tour-price-sub">×4 personas · ~$70K/pers</div></div>
          <div class="tour-cta on">Añadido ✓</div>
